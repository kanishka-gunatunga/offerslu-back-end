# Server
NODE_ENV=development
PORT=4000
API_PREFIX=/api/v1
CORS_ORIGIN=*

# Database (MySQL)
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=offerslu
DB_USER=root
DB_PASSWORD=
DB_DIALECT=mysql
DB_LOGGING=false

# JWT
JWT_SECRET=change_this_to_a_long_random_secret
JWT_EXPIRES_IN=1d

# Initial admin user (used by npm run db:seed)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123

# Rate limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=300

# Uploads
UPLOAD_DIR=uploads
MAX_UPLOAD_SIZE_MB=10

# Logging
LOG_LEVEL=info
